{
  "mcpServers": {
    "gradle": {
      "command": "jbang",
      "args": ["run", "--quiet", "--fresh", "gradle-mcp@rnett"],
      "env": {
        "GRADLE_MCP_PROJECT_ROOT": "D:\\Projects\\Java\\IceCream"
      }
    },
    "maven-tools": {
      "command": "docker",
      "args": ["run", "-i", "--rm", "arvindand/maven-tools-mcp:latest"]
    },
    "papermc-api": {
      "type": "http",
      "url": "https://papermcp.105huadev.com/mcp"
    },
    "git": {
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "D:\\Projects\\Java\\IceCream"]
    }
  }
}
